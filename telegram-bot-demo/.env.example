# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telethon user account credentials (from https://my.telegram.org/apps)
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH

# Target group username or ID (e.g. @mygroup or -1001234567890)
TARGET_GROUP=@your_group_username

# Output directory for dumped messages
OUTPUT_DIR=./output

# Dump batch size (messages per request, max 100)
BATCH_SIZE=100
